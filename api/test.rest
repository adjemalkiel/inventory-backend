Accept: application/json

###############################################################################
### users (Django auth_user — integer pk; password write-only, never in responses)
GET {{api}}/users/
Accept: application/json

### users — create
# @name createUser
POST {{api}}/users/
Content-Type: application/json

{
  "username": "api-test-user",
  "email": "apitest@example.com",
  "first_name": "API",
  "last_name": "Test",
  "password": "change-me-securely",
  "is_active": true,
  "is_staff": false,
  "is_superuser": false
}

### users — detail
GET {{api}}/users/{{createUser.response.body.id}}/
Accept: application/json

### users — partial update (omit password to leave unchanged)
PATCH {{api}}/users/{{createUser.response.body.id}}/
Content-Type: application/json

{
  "first_name": "API-Updated"
}

### users — delete
# DELETE {{api}}/users/{{createUser.response.body.id}}/

###############################################################################
### user-profiles (requires valid user pk)
GET {{api}}/user-profiles/
Accept: application/json

### user-profiles — create (needs existing User id)
# @name createUserProfile
POST {{api}}/user-profiles/
Content-Type: application/json

{
  "user": {{userId}},
  "role": "magasinier",
  "job_title": "Tester",
  "site": "{{createSite.response.body.id}}"
}

### user-profiles — detail
GET {{api}}/user-profiles/{{createUserProfile.response.body.id}}/
Accept: application/json

###############################################################################
### items (needs category + unit)
GET {{api}}/items/
Accept: application/json

### items — create
# @name createItem
POST {{api}}/items/
Content-Type: application/json

{
  "name": "REST Test Item",
  "sku": "REST-SKU-001",
  "category": "{{createCategory.response.body.id}}",
  "unit": "{{createUnit.response.body.id}}",
  "min_stock": "0",
  "is_active": true
}

### items — detail
GET {{api}}/items/{{createItem.response.body.id}}/
Accept: application/json

