# VS Code / IntelliJ HTTP Client — run against a running server:
#   cd inventory-backend && .\env\Scripts\python.exe manage.py runserver
#
# DefaultRouter serves collection + detail: GET/POST /api/<resource>/ and GET/PUT/PATCH/DELETE /api/<resource>/<uuid>/
# Replace @userId if you test user-profiles / user-roles (must exist in auth_user).

@host = http://127.0.0.1:8000
@api = {{host}}/api
@userId = 1

###############################################################################
### API root (route index)
GET {{api}}/
Accept: application/json

###############################################################################
### sites
GET {{api}}/sites/
Accept: application/json

### sites — create
# @name createSite
POST {{api}}/sites/
Content-Type: application/json

{
  "name": "REST Test Site",
  "code": "RTS"
}

### sites — detail
GET {{api}}/sites/{{createSite.response.body.id}}/
Accept: application/json

### sites — partial update
PATCH {{api}}/sites/{{createSite.response.body.id}}/
Content-Type: application/json

{
  "code": "RTS-UPD"
}

###############################################################################
### agencies
GET {{api}}/agencies/
Accept: application/json

### agencies — create
# @name createAgency
POST {{api}}/agencies/
Content-Type: application/json

{
  "name": "REST Test Agency"
}

### agencies — detail
GET {{api}}/agencies/{{createAgency.response.body.id}}/
Accept: application/json

